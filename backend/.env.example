# Server
NODE_ENV=development
PORT=3000

# Database (SQLite for development)
DATABASE_URL="file:./dev.db"

# JWT
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (configure with your SMTP provider)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@ai-subscription-trimmer.com

# Application URLs (used in email links)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Token expiry (in milliseconds)
EMAIL_VERIFICATION_TOKEN_EXPIRES_MS=86400000
PASSWORD_RESET_TOKEN_EXPIRES_MS=3600000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10
